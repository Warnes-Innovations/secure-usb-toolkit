# Container size (e.g. 1G, 500M)
SIZE=1G
# Output path for the VeraCrypt container
OUTPUT_CONTAINER=../output.vc
# Volume type: Normal (standard) or Hidden
VOLUME_TYPE=Normal
# Hash algorithm used for key derivation: SHA-512, SHA-256, Whirlpool, BLAKE2s-256
HASH=SHA-512
# NOTE: Passwords are never stored here. You will be prompted at creation time.
